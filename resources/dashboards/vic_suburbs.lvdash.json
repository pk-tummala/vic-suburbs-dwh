{
  "datasets": [
    {
      "name": "b781d400",
      "displayName": "KPIs",
      "query": "SELECT sal_code, lga_code, year FROM `04_reporting`.vw_q1_population_growth"
    },
    {
      "name": "7a721646",
      "displayName": "Q1 population growth",
      "query": "SELECT suburb_name, lga_name, year, population_total FROM `04_reporting`.vw_q1_population_growth"
    },
    {
      "name": "d411b49b",
      "displayName": "Q3 crime over time",
      "query": "SELECT suburb_name, lga_name, year, offence_count_total FROM `04_reporting`.vw_q3_low_crime"
    },
    {
      "name": "b5088819",
      "displayName": "Q6 house price over time",
      "query": "SELECT suburb_name, lga_name, year, median_house_price FROM `04_reporting`.vw_q6_most_expensive"
    },
    {
      "name": "e8c078a0",
      "displayName": "Q2 transport connectivity",
      "query": "SELECT suburb_name, lga_name, 'Train' AS mode, train_station_count AS stops FROM `04_reporting`.vw_q2_transport_connectivity UNION ALL SELECT suburb_name, lga_name, 'Tram', tram_stop_count FROM `04_reporting`.vw_q2_transport_connectivity UNION ALL SELECT suburb_name, lga_name, 'Bus', bus_stop_count FROM `04_reporting`.vw_q2_transport_connectivity"
    },
    {
      "name": "6bbfae5a",
      "displayName": "Q4 top schools",
      "query": "WITH latest_pop AS (  SELECT suburb_name, population_total,         ROW_NUMBER() OVER (PARTITION BY suburb_name ORDER BY year DESC) AS rn  FROM `04_reporting`.vw_q1_population_growth) SELECT q.suburb_name, q.lga_name, q.govt_school_count, q.mean_icsea,        p.population_total FROM `04_reporting`.vw_q4_top_schools q LEFT JOIN latest_pop p ON p.suburb_name = q.suburb_name AND p.rn = 1"
    },
    {
      "name": "99faf19a",
      "displayName": "Q5 affordable + growth",
      "query": "WITH latest_pop AS (  SELECT suburb_name, population_total,         ROW_NUMBER() OVER (PARTITION BY suburb_name ORDER BY year DESC) AS rn  FROM `04_reporting`.vw_q1_population_growth) SELECT v.suburb_name, v.lga_name, v.current_median, v.cagr_pct,        p.population_total FROM `04_reporting`.vw_q5_affordable_growth v LEFT JOIN latest_pop p ON p.suburb_name = v.suburb_name AND p.rn = 1"
    },
    {
      "name": "5579cea1",
      "displayName": "Best all-round value",
      "query": "WITH crime AS (  SELECT suburb_name, offence_count_total,         ROW_NUMBER() OVER (PARTITION BY suburb_name ORDER BY year DESC) AS rn  FROM `04_reporting`.vw_q3_low_crime), price AS (  SELECT suburb_name, median_house_price,         ROW_NUMBER() OVER (PARTITION BY suburb_name ORDER BY year DESC) AS rn  FROM `04_reporting`.vw_q6_most_expensive), m AS (  SELECT sch.suburb_name, sch.lga_name,         c.offence_count_total AS crime, sch.mean_icsea AS icsea,         t.connectivity_index AS transit, p.median_house_price AS price  FROM `04_reporting`.vw_q4_top_schools sch  LEFT JOIN crime c ON c.suburb_name = sch.suburb_name AND c.rn = 1  LEFT JOIN `04_reporting`.vw_q2_transport_connectivity t       ON t.suburb_name = sch.suburb_name  LEFT JOIN price p ON p.suburb_name = sch.suburb_name AND p.rn = 1), n AS (  SELECT suburb_name, lga_name,    ROUND(25*(1-(crime-MIN(crime) OVER())             /NULLIF(MAX(crime) OVER()-MIN(crime) OVER(),0)), 1) AS s_safety,    ROUND(25*((icsea-MIN(icsea) OVER())             /NULLIF(MAX(icsea) OVER()-MIN(icsea) OVER(),0)), 1) AS s_schools,    ROUND(25*((transit-MIN(transit) OVER())             /NULLIF(MAX(transit) OVER()-MIN(transit) OVER(),0)), 1) AS s_transit,    ROUND(25*(1-(price-MIN(price) OVER())             /NULLIF(MAX(price) OVER()-MIN(price) OVER(),0)), 1) AS s_afford  FROM m) SELECT suburb_name, lga_name, 'Safety (low crime)' AS factor, s_safety  AS score FROM n UNION ALL SELECT suburb_name, lga_name, 'Schools (ICSEA)',    s_schools FROM n UNION ALL SELECT suburb_name, lga_name, 'Transit',            s_transit FROM n UNION ALL SELECT suburb_name, lga_name, 'Affordability',      s_afford  FROM n"
    }
  ],
